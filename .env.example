# .env.example — Variáveis de ambiente do projeto
#
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# NUNCA suba o arquivo .env para o GitHub.

# ─── LLM Router ───────────────────────────────────────────────────────────────
#
# Modo de operação do LLM.
# "dry-run" (padrão): custo zero, sem chamada real. Sistema funciona completo.
# "real": ativa chamadas à API Anthropic — exige ANTHROPIC_API_KEY preenchida.
#
LLM_MODO=dry-run

# Chave de API Anthropic — necessária SOMENTE quando LLM_MODO=real.
# Obter em: https://console.anthropic.com/settings/keys
# Deixe como está enquanto operar em dry-run.
#
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Outras APIs (futuro) ─────────────────────────────────────────────────────
#
# GOOGLE_MAPS_API_KEY=sua_chave_aqui
